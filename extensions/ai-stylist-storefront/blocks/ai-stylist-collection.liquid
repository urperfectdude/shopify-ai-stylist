{% assign ai_stylist_api_url = block.settings.api_url | default: app.metafields.ai_stylist.app_url %}

<div
  class="ai-stylist-block"
  data-ai-stylist
  data-surface="collection"
  data-api-url="{{ ai_stylist_api_url | escape }}"
  data-shop-domain="{{ shop.permanent_domain | escape }}"
  data-collection-handle="{{ collection.handle | escape }}"
  data-product-limit="{{ block.settings.product_limit }}"
>
  <div class="ai-stylist-block__shell">
    <p class="ai-stylist-block__eyebrow">AI Stylist</p>
    <h3 class="ai-stylist-block__title">{{ block.settings.heading }}</h3>
    <p class="ai-stylist-block__copy">{{ block.settings.description }}</p>
    <button type="button" class="ai-stylist-block__button" data-ai-stylist-generate>
      {{ block.settings.button_label }}
    </button>
    <div class="ai-stylist-block__results" data-ai-stylist-results></div>
  </div>
</div>

{% schema %}
{
  "name": "AI Stylist collection",
  "target": "section",
  "stylesheet": "ai-stylist.css",
  "javascript": "ai-stylist.js",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collection outfit generator"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Turn the current collection into coordinated outfits and add-on recommendations."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Build collection look"
    },
    {
      "type": "range",
      "id": "product_limit",
      "label": "Products to pass into AI context",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "api_url",
      "label": "AI Stylist app URL",
      "info": "Optional override. Defaults to the app URL exposed by your app."
    }
  ]
}
{% endschema %}
